# Copy to .env and adjust values.
# Most app settings use the ZERO_ prefix. OPENAI_* and WECOM_* keep legacy names.

# --- LLM (Agent / Deep Agents) ---
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_MODEL=gpt-4o-mini

# Agent workspace root (Deep Agents filesystem backend; notes and personal files)
ZERO_WORKSPACE_DIR=.

TAVILY_API_KEY=tvly-your-api-key-here

# --- Gateway (WeCom MVP) ---
WECOM_BOT_ID=
WECOM_BOT_SECRET=

# --- Storage ---
ZERO_DATA_DIR=.local
# ZERO_SESSION_DB_PATH=.local/session.db
# ZERO_CHECKPOINT_DB_PATH=.local/checkpoints.db

# --- Session / i18n ---
ZERO_DEFAULT_LOCALE=zh
ZERO_SESSION_TTL_SECONDS=604800

# --- Observability (structlog) ---
ZERO_LOG_LEVEL=INFO
ZERO_LOG_JSON=true
